---
import ProjectLayout from '../../layouts/ProjectLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<ProjectLayout
  title="Israel Train Stations Dashboard"
  year="2025"
  section="Data Science & Analysis"
  category="Interactive Dashboard · Streamlit"
  tools={['Python', 'Streamlit', 'Pandas', 'Plotly', 'Folium', 'GTFS']}
>

  <section class="proj-section">
    <h2 class="proj-section-title">Background</h2>
    <div class="proj-body">
      <p>
        Israel Railways publishes detailed open data on station activity, but digging through it
        station-by-station takes real effort. This project turns that raw data into an interactive
        dashboard that lets planners, researchers — or curious commuters — explore departure
        patterns across the network without writing code.
      </p>
    </div>
  </section>

  <section class="proj-section">
    <h2 class="proj-section-title">Screenshots</h2>
    <img
      src={`${base}/maps/train-stations-dashboard-overview.png`}
      alt="Israel Train Stations Dashboard showing the station selector, date-range controls and a line chart of monthly average daily departures for Tel Aviv Ha'Hagana station"
      class="proj-map"
      loading="lazy"
    />
    <p class="proj-map-caption">
      Station explorer view — pick a station and date range to see its average daily departures trend over time.
    </p>
    <img
      src={`${base}/maps/train-stations-dashboard-detail.jpg`}
      alt="Dashboard detail view showing a time-of-day departure share bar chart, a weekday distribution pie chart, and an embedded Folium map of the station location"
      class="proj-map"
      loading="lazy"
    />
    <p class="proj-map-caption">
      Time-of-day and weekday distributions alongside an embedded map of the selected station's location.
    </p>
  </section>

  <section class="proj-section">
    <h2 class="proj-section-title">Methodology</h2>
    <ul class="proj-list">
      <li>Combined departure-activity data from the <strong>Israeli Government Open Data Portal</strong> with <strong>GTFS</strong> station coordinates and 2025 schedules, processed in <strong>Pandas</strong>.</li>
      <li>Built an interactive <strong>Streamlit</strong> app for exploring any station's activity at day, month or year resolution, with custom date-range comparisons.</li>
      <li>Implemented working-day logic separating regular service from weekends and Israeli holidays (Jewish calendar), so trends reflect real operating patterns.</li>
      <li>Visualized time-of-day distribution with <strong>Plotly</strong> charts and an embedded <strong>Folium</strong> map for geographic context.</li>
    </ul>
  </section>

  <section class="proj-section">
    <h2 class="proj-section-title">Results</h2>
    <div class="proj-body">
      <p>
        The dashboard is live on Streamlit Community Cloud, letting anyone spot peak-hour loads,
        off-peak gaps and long-term ridership trends across Israel's rail network — no code required.
      </p>
    </div>
  </section>

  <section class="proj-section">
    <h2 class="proj-section-title">Try It / Code</h2>
    <p class="proj-body">
      The dashboard is deployed live on Streamlit Community Cloud, and the full source is on GitHub.
    </p>
    <div class="proj-links">
      <a class="proj-external proj-external-primary" href="https://israeltrainstationsproject.streamlit.app/" target="_blank" rel="noopener noreferrer">
        Open live dashboard →
      </a>
      <a class="proj-external" href="https://github.com/ofer-geo/israel_train_stations_project" target="_blank" rel="noopener noreferrer">
        View repository on GitHub →
      </a>
    </div>
  </section>

</ProjectLayout>

<style>
  :global(.proj-list) {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
    max-width: 68ch;
  }
  :global(.proj-list li) {
    font-size: 0.9rem;
    line-height: 1.7;
    color: #2A2A2A;
    padding-left: 1.2em;
    position: relative;
  }
  :global(.proj-list li::before) {
    content: '—';
    position: absolute;
    left: 0;
    color: #3D5E35;
    font-weight: 600;
  }

  .proj-links {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 12px;
  }
  .proj-external {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: 600;
    color: #3D5E35;
    text-decoration: none;
  }
  .proj-external:hover { text-decoration: underline; }
  .proj-external-primary {
    padding: 10px 20px;
    color: #F0EAE0;
    background: #3D5E35;
    border-radius: 4px;
    transition: background 0.15s;
  }
  .proj-external-primary:hover { background: #2E4828; text-decoration: none; }
</style>

---
const experience = [
  {
    period: '2025 – Present',
    role: 'Data Systems & Geospatial Project Lead',
    org: 'Sivan Design D.S LTD — Israel / Zanzibar / Nigeria',
    bullets: [
      'Translating government and operational requirements into data structures, analytical workflows, and system requirements for national geospatial data programs.',
      'Leading cross-functional technical delivery across developers, GIS specialists, and client stakeholders, aligning data architecture and platform capabilities with business and operational needs.',
      'Designing data schemas, metadata structures, and system architecture for national-scale spatial data infrastructure (SDI) programs (ZanSDI, Ogun State SDI), including deployment of an open-source geospatial stack (GeoNode, GeoServer, PostGIS).',
      'Preparing technical documentation, including data model design and integration specifications for multi-machine environments.',
    ],
  },
  {
    period: '2022 – 2025',
    role: 'Transportation & Geospatial Data Analyst',
    org: 'Tel Aviv-Yafo Municipality, Tel-Aviv',
    bullets: [
      'Automated data processes integrating GTFS, SIRI, and e-scooter datasets to support transportation analytics.',
      'Applied statistical and spatial analysis to uncover mobility patterns, delivering dashboards that informed planning decisions.',
    ],
  },
  {
    period: '2024',
    role: 'GIS Academic Teaching Assistant',
    org: 'Tel Aviv University, Tel-Aviv',
    bullets: [
      'Preparing Basic and Advanced GIS practical courses in QGIS and ArcGIS, and delivering them.',
    ],
  },
  {
    period: '2023',
    role: 'Geospatial Analyst & Researcher',
    org: 'Freelance',
    bullets: [
      'Conducted freelance research commissioned by the Tel Aviv-Yafo Municipality, analyzing ~1M shared e-scooter trips using statistical modeling and spatial analysis to inform micro-mobility parking policy.',
    ],
  },
  {
    period: '2021 – 2022',
    role: 'Research Assistant',
    org: 'Geo-Simulation Lab, Tel Aviv University, Tel-Aviv',
    bullets: [
      'Participated in joint research with the University of Manchester.',
    ],
  },
  {
    period: '2021 – 2022',
    role: 'Geospatial Data Analyst',
    org: 'Competition Authority, Jerusalem',
    bullets: [
      'Applied geographic principles in departmental research projects.',
      'Utilized GIS tools and methodologies to enhance decision-making.',
    ],
  },
  {
    period: '2020 – 2021',
    role: 'GIS Operator',
    org: 'Ministry of Environmental Protection, Jerusalem',
    bullets: [
      'Managed and enhanced GIS data for the Environmental Planning Department.',
    ],
  },
];

const education = [
  {
    period: '2025 – 2026',
    degree: 'Certified Data Scientist — Generative AI & AI Agents',
    institution: 'Bar-Ilan University',
    details: [],
  },
  {
    period: '2022 – 2024',
    degree: "Master's Degree in Geography (Thesis Track)",
    institution: 'Tel Aviv University — Geosimulation Lab',
    details: [
      'Thesis: "The Impact of Cycling Infrastructure on Shared Dockless E-Scooter Riders\' Usage Patterns and Travel Behavior"',
      'Final grade: 94 — Magna Cum Laude',
    ],
  },
  {
    period: '2018 – 2022',
    degree: "Bachelor's Degree",
    institution: 'Tel Aviv University',
    details: [
      'Geography & the Human Environment — 96, Summa Cum Laude',
      'Middle Eastern & African History — 93, Magna Cum Laude',
    ],
  },
];
---
<div class="panel-inner">
  <h2 class="panel-title">Resume</h2>

  <div class="resume-columns">
    <!-- Experience -->
    <div class="resume-group">
      <h3 class="group-heading">Experience</h3>
      <div class="timeline">
        {experience.map(item => (
          <div class="tl-item">
            <div class="tl-line" aria-hidden="true">
              <div class="tl-dot"></div>
            </div>
            <div class="tl-body">
              <span class="tl-period">{item.period}</span>
              <h4 class="tl-role">{item.role}</h4>
              <p class="tl-org">{item.org}</p>
              <ul class="tl-bullets">
                {item.bullets.map(b => <li>{b}</li>)}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Education -->
    <div class="resume-group">
      <h3 class="group-heading">Education</h3>
      <div class="timeline">
        {education.map(item => (
          <div class="tl-item">
            <div class="tl-line" aria-hidden="true">
              <div class="tl-dot"></div>
            </div>
            <div class="tl-body">
              <span class="tl-period">{item.period}</span>
              <h4 class="tl-role">{item.degree}</h4>
              <p class="tl-org">{item.institution}</p>
              {item.details.length > 0 && (
                <ul class="tl-bullets">
                  {item.details.map(d => <li>{d}</li>)}
                </ul>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</div>

<style>
.resume-columns {
  display: grid;
  grid-template-columns: 1fr 320px;
  gap: 64px;
  align-items: start;
}

.group-heading {
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--ct-accent);
  margin-bottom: 28px;
}

/* Timeline */
.timeline { display: flex; flex-direction: column; }

.tl-item {
  display: grid;
  grid-template-columns: 20px 1fr;
  gap: 16px;
  padding-bottom: 32px;
  position: relative;
}
.tl-item:last-child { padding-bottom: 0; }

.tl-line {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 4px;
}
.tl-dot {
  width: 9px;
  height: 9px;
  border-radius: 50%;
  background: var(--ct-accent);
  border: 2px solid var(--ct-bg);
  outline: 1.5px solid var(--ct-accent);
  flex-shrink: 0;
}
.tl-item:not(:last-child) .tl-line::after {
  content: '';
  flex: 1;
  width: 1.5px;
  background: var(--ct-border);
  margin-top: 6px;
}

.tl-period {
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.05em;
  color: var(--ct-muted);
  display: block;
  margin-bottom: 4px;
}
.tl-role {
  font-size: 0.92rem;
  font-weight: 600;
  color: var(--ct-text);
  margin-bottom: 2px;
  line-height: 1.35;
}
.tl-org {
  font-size: 0.82rem;
  color: var(--ct-muted);
  margin-bottom: 8px;
  line-height: 1.4;
}

.tl-bullets {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 5px;
}
.tl-bullets li {
  font-size: 0.84rem;
  color: var(--ct-muted);
  line-height: 1.6;
  padding-left: 14px;
  position: relative;
}
.tl-bullets li::before {
  content: '·';
  position: absolute;
  left: 0;
  color: var(--ct-accent);
  font-size: 1.1rem;
  line-height: 1.4;
}

@media (max-width: 800px) {
  .resume-columns { grid-template-columns: 1fr; gap: 40px; }
}
</style>

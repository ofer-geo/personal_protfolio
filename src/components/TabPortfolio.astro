---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const sections = [
  {
    id: 'datascience',
    label: 'Data Science & Analysis',
    projects: [
      {
        title: "Cycling Infrastructure & Shared E-Scooter Behaviour — MSc Thesis",
        desc: 'Master\'s thesis analysing ~1M shared e-scooter trips in Tel Aviv-Yafo to measure how cycling infrastructure shapes route choice, parking location and demand.',
        tags: ['Python', 'GeoPandas', 'Map Matching', 'Statistical Analysis', 'GIS'],
        thumb: `${base}/maps/thesis-route-vs-shortest-path.jpg`,
        href: `${base}/projects/escooter-cycling-thesis`,
      },
      {
        title: 'Predicting Bus Trip Performance with Machine Learning',
        desc: 'XGBoost classifier predicting whether a bus trip runs early, on-time or delayed from GTFS, SIRI and weather data — built with Tamir Edelstein (Elia Transportation Engineering) for Bar-Ilan University\'s Data Science programme.',
        tags: ['Python', 'XGBoost', 'SHAP', 'Optuna', 'scikit-learn'],
        thumb: `${base}/maps/ml-bus-delay-roc-curves.jpg`,
        href: `${base}/projects/bus-delay-prediction`,
      },
      {
        title: 'Israel Train Stations Dashboard',
        desc: 'Interactive Streamlit dashboard exploring passenger departure patterns across Israel Railways stations — built on open GTFS and government transport data, deployed live on Streamlit Community Cloud.',
        tags: ['Python', 'Streamlit', 'Plotly', 'Folium', 'GTFS'],
        thumb: `${base}/maps/train-stations-dashboard-overview.png`,
        href: `${base}/projects/train-stations-dashboard`,
      },
    ],
  },
  {
    id: 'gispm',
    label: 'GIS Project Management',
    projects: [
      {
        title: 'ZanSDI — Zanzibar Spatial Data Infrastructure',
        desc: 'Technical Project Manager for Zanzibar\'s national geoportal: leading system design, development and capacity building for a World Bank–funded SDI built on GeoNode, GeoServer and PostGIS.',
        tags: ['GeoNode', 'System Design', 'Team Leadership', 'Jira', 'Capacity Building'],
        thumb: `${base}/maps/zansdi-landing-page.jpg`,
        href: `${base}/projects/zansdi`,
      },
      {
        title: 'Ogun SDI & LULC Mapping',
        desc: 'Technical Project Manager for Ogun State\'s SDI and statewide Land Use/Land Cover mapping — directing the design of the Geom Tool and the OLARMS land-administration integration to meet the Bureau of Lands and Survey\'s workflow needs.',
        tags: ['GeoNode', 'System Integration', 'Tool Design', 'LULC'],
        thumb: `${base}/maps/ogun-sdi-web-map.jpg`,
        href: `${base}/projects/ogun-sdi`,
      },
    ],
  },
  {
    id: 'maps',
    label: 'Maps & Geospatial Analysis',
    projects: [
      {
        title: 'Near-Home Parking: Shortest-Path Lot Assignment',
        desc: 'Network model using OSM walking distances to assign every residential street to its optimal night parking lot, with load indexing across all city quarters.',
        tags: ['Python', 'OSMnx', 'NetworkX', 'QGIS', 'Shortest Path'],
        thumb: `${base}/maps/night-parking-network.png`,
        href: `${base}/projects/night-parking`,
      },
      {
        title: 'Contraflow Riding on One-Way Streets',
        desc: 'Mapped shared e-scooter trips against traffic direction in Tel Aviv to quantify contraflow patterns and identify high-risk corridors.',
        tags: ['Python', 'GeoPandas', 'QGIS', 'OpenStreetMap'],
        thumb: `${base}/maps/contraflow.png`,
        href: `${base}/projects/contraflow`,
      },
      {
        title: 'Spatial Equity of Shared Micro-Mobility',
        desc: 'Kernel density analysis of e-scooter availability across peripheral quarters, exposing supply-demand gaps in underserved neighborhoods.',
        tags: ['Python', 'SciPy', 'KDE', 'QGIS', 'TAZ Analysis'],
        thumb: `${base}/maps/scooter-kde-density.png`,
        href: `${base}/projects/scooter-density`,
      },
      {
        title: 'Who Pays to Park? Neighborhood Parking Equity',
        desc: 'Choropleth analysis of paid vs. free parking distribution across Tel Aviv neighborhoods, surfacing equity implications of pricing policy.',
        tags: ['Python', 'QGIS', 'Choropleth', 'Spatial Join'],
        thumb: `${base}/maps/parking-free-neighborhood.png`,
        href: `${base}/projects/parking-policy`,
      },
      {
        title: 'Fleet Distribution at Special Events',
        desc: 'Analyzed shared e-scooter distribution during Tel Aviv\'s Pride Parade to map peak-hour supply gaps and support pre-positioning decisions.',
        tags: ['Python', 'GeoPandas', 'QGIS', 'Density Mapping'],
        thumb: `${base}/maps/pride-distribution.jpg`,
        href: `${base}/projects/pride-events`,
      },
      {
        title: 'Bus Service Frequency Changes: 2022–2024',
        desc: 'Year-over-year GTFS analysis mapping where bus service improved or degraded across Tel Aviv, tracking the impact of light rail integration.',
        tags: ['Python', 'GTFS', 'GeoPandas', 'QGIS', 'Temporal Analysis'],
        thumb: `${base}/maps/freq-2023-2024.jpg`,
        href: `${base}/projects/service-frequency`,
      },
    ],
  },
];
---
<div class="panel-inner port-panel">
  <h2 class="panel-title">Portfolio</h2>

  <!-- Sub-navigation -->
  <nav class="port-subnav" id="port-subnav" aria-label="Portfolio sections">
    {sections.map((s, i) => (
      <button
        class={`port-subnav-btn${i === 0 ? ' active' : ''}`}
        data-psection={s.id}
        aria-label={`Jump to ${s.label}`}
      >
        {s.label}
      </button>
    ))}
  </nav>

  <!-- Sections -->
  {sections.map(section => (
    <div class="port-section" id={section.id} data-section={section.id}>
      <h3 class="port-section-title">{section.label}</h3>
      <div class="port-grid">
        {section.projects.map(project => (
          project.href ? (
            <a href={project.href} class="card port-card port-card-link">
              {project.thumb && (
                <div class="port-thumb">
                  <img src={project.thumb} alt={project.title} loading="lazy" />
                </div>
              )}
              <div class="port-card-body">
                <h4 class="port-card-title">{project.title}</h4>
                <p class="port-card-desc">{project.desc}</p>
                <div class="tags">
                  {project.tags.map(t => <span class="tag">{t}</span>)}
                </div>
                <span class="port-card-cta">View project →</span>
              </div>
            </a>
          ) : (
            <div class="card port-card port-card-placeholder">
              <div class="port-card-body">
                <h4 class="port-card-title fill-later">{project.title}</h4>
              </div>
            </div>
          )
        ))}
      </div>
    </div>
  ))}
</div>

<style>
.port-panel { padding-bottom: 80px; }

/* Sub-nav */
.port-subnav {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 48px;
  padding: 20px 0 24px;
  border-bottom: 1px solid var(--ct-border);
  position: sticky;
  top: var(--tab-h);
  background: var(--ct-bg);
  z-index: 5;
}

.port-subnav-btn {
  padding: 7px 16px;
  font-size: 0.82rem;
  font-weight: 500;
  font-family: inherit;
  color: var(--ct-muted);
  background: transparent;
  border: 1.5px solid var(--ct-border);
  border-radius: 20px;
  cursor: pointer;
  transition: all 0.15s;
  white-space: nowrap;
}
.port-subnav-btn:hover {
  color: var(--ct-accent);
  border-color: var(--ct-accent);
  background: var(--ct-accent-lt);
}
.port-subnav-btn.active {
  color: var(--ct-accent);
  border-color: var(--ct-accent);
  background: var(--ct-accent-lt);
  font-weight: 600;
}

/* Sections */
.port-section { margin-bottom: 64px; }
.port-section:last-child { margin-bottom: 0; }

.port-section-title {
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--ct-text);
  margin-bottom: 20px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--ct-border);
  letter-spacing: -0.01em;
}

/* Card grid — 3 columns for maps section */
.port-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18px;
}

/* Cards */
.port-card-link {
  text-decoration: none;
  color: inherit;
  display: flex;
  flex-direction: column;
  transition: box-shadow 0.15s, transform 0.15s;
}
.port-card-link:hover {
  box-shadow: 0 6px 24px rgba(44,36,22,0.1);
  transform: translateY(-2px);
}

.port-card-placeholder {
  opacity: 0.5;
  min-height: 80px;
}

/* Thumbnail */
.port-thumb {
  border-bottom: 1px solid var(--ct-border);
  aspect-ratio: 16/9;
  overflow: hidden;
  background: #EDE8DF;
}
.port-thumb img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.3s ease;
}
.port-card-link:hover .port-thumb img {
  transform: scale(1.03);
}

/* Card body */
.port-card-body {
  padding: 16px 18px 18px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  flex: 1;
}

.port-card-title {
  font-size: 0.88rem;
  font-weight: 600;
  color: var(--ct-text);
  line-height: 1.4;
}

.port-card-desc {
  font-size: 0.79rem;
  line-height: 1.6;
  color: var(--ct-muted);
  flex: 1;
}

.port-card-cta {
  font-size: 0.75rem;
  font-weight: 600;
  color: var(--ct-accent);
  margin-top: 4px;
  display: block;
}

@media (max-width: 1100px) {
  .port-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 900px) {
  .port-subnav { top: var(--tab-h); }
}
@media (max-width: 560px) {
  .port-grid { grid-template-columns: 1fr; }
}
</style>

<script>
  const subBtns = document.querySelectorAll<HTMLButtonElement>('.port-subnav-btn');

  subBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const id = btn.dataset.psection!;
      const section = document.getElementById(id);
      if (!section) return;

      const tabNavH = parseInt(
        getComputedStyle(document.documentElement).getPropertyValue('--tab-h') || '54'
      );
      const subNavH = (document.getElementById('port-subnav')?.offsetHeight ?? 0);
      const y = section.getBoundingClientRect().top + window.scrollY - tabNavH - subNavH - 8;
      window.scrollTo({ top: y, behavior: 'smooth' });
    });
  });

  const portSections = document.querySelectorAll<HTMLElement>('.port-section');
  const observer = new IntersectionObserver(
    entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const id = entry.target.getAttribute('data-section');
          subBtns.forEach(b => b.classList.toggle('active', b.dataset.psection === id));
        }
      });
    },
    { rootMargin: '-30% 0px -60% 0px' }
  );
  portSections.forEach(s => observer.observe(s));
</script>

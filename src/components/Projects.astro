---
const projects = [
  {
    title: 'NSDI Zanzibar',
    subtitle: 'National Spatial Data Infrastructure — design and implementation',
    role: 'Project Manager',
    period: '2022 — Present',
    featured: true,
    outcomes: [
      'Established the legal and institutional framework for spatial data governance in Zanzibar',
      'Coordinated 8 government agencies and international partners in data harmonisation',
      'Deployed a centralised geoportal serving cadastral, administrative, and environmental layers',
      'Delivered capacity-building workshops for 40+ government GIS officers across departments',
    ],
    tags: ['GIS Governance', 'Institutional', 'Capacity Building', 'Geoportal'],
  },
  {
    title: 'Zanzibar Transportation Network Study',
    subtitle: 'Urban mobility analysis and infrastructure prioritisation',
    role: 'Lead Analyst',
    period: '2023 — 2024',
    featured: false,
    outcomes: [
      'Collected and processed traffic count data at 24 intersections across the island',
      'Built an origin-destination travel demand model for Zanzibar Town',
      'Identified three critical bottleneck corridors for infrastructure investment',
    ],
    tags: ['Transport Modelling', 'Data Analysis', 'Urban Planning'],
  },
  {
    title: 'Land Use & Urban Growth Research',
    subtitle: 'Long-term land use change analysis using satellite imagery',
    role: 'Researcher',
    period: '2022 — 2023',
    featured: false,
    outcomes: [
      'Classified 14 years of Sentinel/Landsat imagery for Unguja Island',
      'Quantified urban expansion rates and the loss of agricultural and coastal land',
      'Produced a peer-reviewed research report for planning authority and policy use',
    ],
    tags: ['Remote Sensing', 'Land Use', 'Research'],
  },
];
---
<section class="section section-alt" id="projects">
  <div class="container">
    <p class="section-label">Projects</p>
    <h2 class="section-title">Selected projects</h2>

    <div class="projects-list">
      {projects.map(p => (
        <div class={`project-card${p.featured ? ' featured' : ''}`}>
          <div class="project-header">
            <div class="project-title-group">
              <h3 class="project-title">{p.title}</h3>
              <p class="project-subtitle">{p.subtitle}</p>
            </div>
            <div class="project-meta">
              <span class="project-role">{p.role}</span>
              <span class="project-period">{p.period}</span>
            </div>
          </div>
          <ul class="project-outcomes">
            {p.outcomes.map(o => <li>{o}</li>)}
          </ul>
          <div class="tags">
            {p.tags.map(t => <span class="tag">{t}</span>)}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
.projects-list { display: flex; flex-direction: column; gap: 20px; }

.project-card {
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 32px;
  transition: box-shadow 0.15s;
}
.project-card:hover { box-shadow: 0 4px 20px rgba(44,36,22,0.07); }
.project-card.featured { border-left: 3px solid var(--accent); }

.project-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 32px;
  margin-bottom: 20px;
}

.project-title {
  font-size: 1.2rem;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 4px;
  letter-spacing: -0.015em;
}
.project-subtitle {
  font-size: 0.875rem;
  color: var(--text-muted);
  line-height: 1.4;
}

.project-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4px;
  flex-shrink: 0;
  padding-top: 2px;
}
.project-role {
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--accent);
}
.project-period {
  font-size: 0.8rem;
  color: var(--text-muted);
}

.project-outcomes {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 8px;
  margin-bottom: 20px;
}
.project-outcomes li {
  font-size: 0.875rem;
  color: var(--text-muted);
  padding-left: 18px;
  position: relative;
  line-height: 1.6;
}
.project-outcomes li::before {
  content: '→';
  position: absolute;
  left: 0;
  color: var(--accent);
  font-size: 0.78rem;
  top: 2px;
}

@media (max-width: 640px) {
  .project-header { flex-direction: column; gap: 12px; }
  .project-meta { align-items: flex-start; }
  .project-card { padding: 20px; }
}
</style>

---
import Layout from './Layout.astro';

export interface Props {
  title: string;
  year?: string;
  category?: string;
  tools?: string[];
}

const { title, year, category, tools = [] } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Layout title={`${title} — Ofer Shahal`}>
  <div class="proj-wrap">

    <aside class="proj-sidebar">
      <div class="proj-sb-top">
        <div class="proj-name">Ofer Shahal</div>
        <div class="proj-role">Geospatial Analyst · GIS PM</div>
      </div>
      <a href={`${base}/`} class="proj-back">← Back to Portfolio</a>
      {category && <div class="proj-cat-label">{category}</div>}
    </aside>

    <main class="proj-main">
      <div class="proj-header">
        <p class="proj-eyebrow">Maps &amp; Geospatial Analysis{year ? ` · ${year}` : ''}</p>
        <h1 class="proj-title">{title}</h1>
        {tools.length > 0 && (
          <div class="tags proj-tags">
            {tools.map(t => <span class="tag">{t}</span>)}
          </div>
        )}
      </div>

      <slot />
    </main>

  </div>
</Layout>

<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

.proj-wrap {
  display: grid;
  grid-template-columns: 280px 1fr;
  min-height: 100vh;
  font-family: 'Inter', system-ui, -apple-system, sans-serif;
  -webkit-font-smoothing: antialiased;
}

/* ── Sidebar ── */
.proj-sidebar {
  position: sticky;
  top: 0;
  height: 100vh;
  overflow-y: auto;
  background: #1B1610;
  border-right: 1px solid #352D25;
  padding: 36px 24px 32px;
  display: flex;
  flex-direction: column;
  gap: 24px;
}

.proj-sb-top { display: flex; flex-direction: column; gap: 4px; }

.proj-name {
  font-size: 1rem;
  font-weight: 700;
  color: #F0EAE0;
  letter-spacing: -0.01em;
}

.proj-role {
  font-size: 0.72rem;
  color: #7A6A5A;
  line-height: 1.4;
}

.proj-back {
  display: inline-flex;
  align-items: center;
  font-size: 0.78rem;
  font-weight: 500;
  color: #6BAA67;
  text-decoration: none;
  padding: 6px 10px;
  border: 1px solid #352D25;
  border-radius: 4px;
  transition: border-color 0.15s, background 0.15s;
  width: fit-content;
}
.proj-back:hover { border-color: #6BAA67; background: rgba(107,170,103,0.08); }

.proj-cat-label {
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #7A6A5A;
  margin-top: auto;
}

/* ── Main content ── */
.proj-main {
  background: #DFDFDF;
  padding: 56px 56px 80px;
  min-height: 100vh;
}

.proj-header { margin-bottom: 40px; }

.proj-eyebrow {
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #3D5E35;
  margin-bottom: 10px;
}

.proj-title {
  font-size: clamp(1.5rem, 3vw, 2.2rem);
  font-weight: 700;
  letter-spacing: -0.025em;
  color: #1A1A1A;
  line-height: 1.2;
  margin-bottom: 16px;
}

.proj-tags { margin-top: 16px; }

/* ── Section headings ── */
:global(.proj-section) { margin-bottom: 48px; }
:global(.proj-section-title) {
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #3D5E35;
  margin-bottom: 16px;
  padding-bottom: 8px;
  border-bottom: 1px solid #C4C4C4;
}

/* ── Map images ── */
:global(.proj-map) {
  width: 100%;
  max-width: 820px;
  border-radius: 4px;
  border: 1px solid #C4C4C4;
  display: block;
  margin-bottom: 12px;
}
:global(.proj-map-caption) {
  font-size: 0.75rem;
  color: #6B6B6B;
  margin-bottom: 32px;
  font-style: italic;
}
:global(.proj-map-grid) {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  margin-bottom: 32px;
}
:global(.proj-map-grid .proj-map) { margin-bottom: 6px; }

/* ── Body text ── */
:global(.proj-body) {
  font-size: 0.9rem;
  line-height: 1.75;
  color: #2A2A2A;
  max-width: 68ch;
}
:global(.proj-body p + p) { margin-top: 1em; }

/* ── Tags (inherited from global) ── */
.tag {
  font-size: 0.68rem;
  font-weight: 500;
  background: #E8F2E8;
  color: #3D5E35;
  padding: 3px 8px;
  border-radius: 3px;
  letter-spacing: 0.02em;
}
.tags { display: flex; flex-wrap: wrap; gap: 6px; }

/* ── Mobile ── */
@media (max-width: 860px) {
  .proj-wrap { grid-template-columns: 1fr; }
  .proj-sidebar {
    position: static;
    height: auto;
    flex-direction: row;
    flex-wrap: wrap;
    align-items: center;
    gap: 16px;
    padding: 20px;
  }
  .proj-cat-label { margin-top: 0; }
  .proj-main { padding: 32px 20px 56px; }
}
</style>
